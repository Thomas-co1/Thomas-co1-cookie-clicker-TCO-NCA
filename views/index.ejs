<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <style>
      .user-header {
        position: absolute;
        top: 20px;
        right: 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        padding: 8px 16px;
        border-radius: 50px;
        border: 1px solid rgba(255, 255, 255, 0.1);
      }
      .username {
        color: #fff;
        font-weight: 600;
        font-size: 0.9rem;
      }
      .logout-btn {
        background: none;
        border: none;
        color: #ef4444;
        cursor: pointer;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 4px 8px;
        border-radius: 4px;
        transition: background 0.3s;
      }
      .logout-btn:hover {
        background: rgba(239, 68, 68, 0.1);
      }
      .auth-links {
        display: flex;
        gap: 12px;
      }
      .auth-link {
        color: #6366f1;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
      }
      .auth-link:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <header class="user-header">
      <% if (user) { %>
        <span class="username"><%= user.username %></span>
        <form action="/users/logout" method="POST" style="margin: 0;">
          <button type="submit" class="logout-btn">Déconnexion</button>
        </form>
      <% } else { %>
        <div class="auth-links">
          <a href="/users/login" class="auth-link">Connexion</a>
          <a href="/users/register" class="auth-link">Inscription</a>
        </div>
      <% } %>
    </header>

    <main class="layout">
      <h1 class="title"><%= title %></h1>
      <p class="subtitle">Clique sur le cookie pour gagner des points.</p>

      <section class="score-card" aria-live="polite">
        <div class="score-group">
          <span class="score-label">Cookies</span>
          <span id="cookie-count" class="score-value">0</span>
        </div>
        <div class="score-group">
          <span class="score-label">Par clic</span>
          <span id="cookies-per-click" class="score-value">1</span>
        </div>
        <div class="score-group">
          <span class="score-label">Cookies / sec</span>
          <span id="cps-count" class="score-value">0</span>
        </div>
      </section>

      <button id="cookie-button" class="cookie-button" type="button" aria-label="Cliquer sur le cookie">
        <span class="cookie-fallback" aria-hidden="true">Cookie</span>
      </button>

      <section class="upgrades-panel">
        <h2 class="section-title">Améliorations</h2>
        <div class="upgrades-list">
          <!-- Super Click Upgrade -->
          <button id="upgrade-click" class="upgrade-item" type="button">
            <div class="upgrade-icon-container">
              <img src="/images/click_upgrade.png" alt="Clic" class="upgrade-icon">
            </div>
            <div class="upgrade-info">
              <span class="upgrade-name">Super Clic</span>
              <span class="upgrade-desc">Augmente les cookies par clic de 1</span>
            </div>
            <div class="upgrade-meta">
              <span class="upgrade-cost"><span id="upgrade-click-cost">10</span> 🍪</span>
              <span class="upgrade-count">Niv. <span id="upgrade-click-count">0</span></span>
            </div>
          </button>

          <!-- Cursor -->
          <button id="buy-cursor" class="upgrade-item buy-building" type="button" data-building-id="cursor">
            <div class="upgrade-icon-container">
              <img src="/images/cursor-icon.png" alt="Cursor" class="upgrade-icon">
            </div>
            <div class="upgrade-info">
              <span class="upgrade-name">Curseur</span>
              <span class="upgrade-desc">Produit 0.1 cookie par seconde</span>
            </div>
            <div class="upgrade-meta">
              <span class="upgrade-cost"><span id="cursor-price">15</span> 🍪</span>
              <span class="upgrade-count">Niv. <span id="cursor-count">0</span></span>
            </div>
          </button>

          <!-- Grandma -->
          <button id="buy-grandma" class="upgrade-item buy-building" type="button" data-building-id="grandma">
            <div class="upgrade-icon-container">
              <img src="/images/grandma_icon.png" alt="Grandma" class="upgrade-icon">
            </div>
            <div class="upgrade-info">
              <span class="upgrade-name">Grand-mère</span>
              <span class="upgrade-desc">Produit 1 cookie par seconde</span>
            </div>
            <div class="upgrade-meta">
              <span class="upgrade-cost"><span id="grandma-price">100</span> 🍪</span>
              <span class="upgrade-count">Niv. <span id="grandma-count">0</span></span>
            </div>
          </button>

          <!-- Farm -->
          <button id="buy-farm" class="upgrade-item buy-building" type="button" data-building-id="farm">
            <div class="upgrade-icon-container">
              <img src="/images/farm_icon.png" alt="Farm" class="upgrade-icon">
            </div>
            <div class="upgrade-info">
              <span class="upgrade-name">Ferme</span>
              <span class="upgrade-desc">Produit 8 cookies par seconde</span>
            </div>
            <div class="upgrade-meta">
              <span class="upgrade-cost"><span id="farm-price">1100</span> 🍪</span>
              <span class="upgrade-count">Niv. <span id="farm-count">0</span></span>
            </div>
          </button>

          <!-- Mine -->
          <button id="buy-mine" class="upgrade-item buy-building" type="button" data-building-id="mine">
            <div class="upgrade-icon-container">
              <img src="/images/mine_icon.png" alt="Mine" class="upgrade-icon">
            </div>
            <div class="upgrade-info">
              <span class="upgrade-name">Mine</span>
              <span class="upgrade-desc">Produit 47 cookies par seconde</span>
            </div>
            <div class="upgrade-meta">
              <span class="upgrade-cost"><span id="mine-price">12000</span> 🍪</span>
              <span class="upgrade-count">Niv. <span id="mine-count">0</span></span>
            </div>
          </button>

          <!-- Factory -->
          <button id="buy-factory" class="upgrade-item buy-building" type="button" data-building-id="factory">
            <div class="upgrade-icon-container">
              <img src="/images/factory_icon.png" alt="Factory" class="upgrade-icon">
            </div>
            <div class="upgrade-info">
              <span class="upgrade-name">Usine</span>
              <span class="upgrade-desc">Produit 260 cookies par seconde</span>
            </div>
            <div class="upgrade-meta">
              <span class="upgrade-cost"><span id="factory-price">130000</span> 🍪</span>
              <span class="upgrade-count">Niv. <span id="factory-count">0</span></span>
            </div>
          </button>

          <!-- Bank -->
          <button id="buy-bank" class="upgrade-item buy-building" type="button" data-building-id="bank">
            <div class="upgrade-icon-container">
              <img src="/images/bank_icon.png" alt="Bank" class="upgrade-icon">
            </div>
            <div class="upgrade-info">
              <span class="upgrade-name">Banque</span>
              <span class="upgrade-desc">Produit 1400 cookies par seconde</span>
            </div>
            <div class="upgrade-meta">
              <span class="upgrade-cost"><span id="bank-price">1400000</span> 🍪</span>
              <span class="upgrade-count">Niv. <span id="bank-count">0</span></span>
            </div>
          </button>

          <!-- Temple -->
          <button id="buy-temple" class="upgrade-item buy-building" type="button" data-building-id="temple">
            <div class="upgrade-icon-container">
              <img src="/images/temple_icon.png" alt="Temple" class="upgrade-icon">
            </div>
            <div class="upgrade-info">
              <span class="upgrade-name">Temple</span>
              <span class="upgrade-desc">Produit 7800 cookies par seconde</span>
            </div>
            <div class="upgrade-meta">
              <span class="upgrade-cost"><span id="temple-price">20000000</span> 🍪</span>
              <span class="upgrade-count">Niv. <span id="temple-count">0</span></span>
            </div>
          </button>

        </div>
      </section>
    </main>

    <script src='/javascripts/clicker.js'></script>
  </body>
</html>
